# ═══════════════════════════════════════════════════
# Argos Backend — Environment Variables Template
# ═══════════════════════════════════════════════════

# Supabase Configuration
SUPABASE_URL=your_supabase_project_url
SUPABASE_KEY=your_supabase_service_role_key

# Neo4j Configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password
NEO4J_DATABASE=neo4j

# LLM APIs Configuration
GOOGLE_API_KEY=your_google_api_key
GROQ_API_KEY=your_groq_api_key

# Reddit API Configuration (For Reddit Agent)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=Argos/1.0

# ProductHunt API Configuration (For ProductHunt Agent)
PRODUCTHUNT_DEVELOPER_TOKEN=your_producthunt_developer_token

# Telegram Bot Integration (For Alerts delivery)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Gmail SMTP Configuration (For Email Digest delivery)
GMAIL_USER=your_gmail_username@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password

# API & Frontend Configuration
API_PORT=8001
NEXT_PUBLIC_API_URL=http://localhost:8001
